{
  "name": "game-brain-mobile",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "scripts": {
    "test": "jest --watchAll",
    "test:ci": "jest --ci",
    "dev": "expo start",
    "build:prod": "eas build --platform ios --profile production",
    "build:preview": "eas build --platform ios --profile preview",
    "build:dev": "eas build --platform ios --profile development",
    "submit": "eas submit --platform ios",
    "eas-build-post-install": "pnpm run generate",
    "postinstall": "pnpm run generate",
    "ios": "expo run ios",
    "clean": "expo prebuild --clean --platform ios",
    "tsc": "tsc --noEmit",
    "lint": "expo lint",
    "lint:fix": "expo lint --fix",
    "generate": "graphql-codegen --config codegen.ts",
    "generate:watch": "graphql-codegen --config codegen.ts --watch",
    "pull-env:dev": "eas env:pull --environment development --non-interactive",
    "pull-env:prod": "eas env:pull --environment production --non-interactive"
  },
  "jest": {
    "preset": "jest-expo",
    "setupFiles": [
      "./node_modules/react-native-gesture-handler/jestSetup.js",
      "./node_modules/react-native-google-mobile-ads/jest.setup.ts"
    ],
    "setupFilesAfterEnv": [
      "./jest-setup.js"
    ],
    "transformIgnorePatterns": [
      "node_modules/(?!(?:.pnpm/)?((jest-)?react-native|@react-native(-community)?|expo(nent)?|@expo(nent)?/.*|@expo-google-fonts/.*|react-navigation|@react-navigation/.*|@sentry/react-native|native-base|react-native-svg))"
    ]
  },
  "dependencies": {
    "@apollo/client": "^4.1.6",
    "@expo/vector-icons": "^15.1.1",
    "@react-navigation/bottom-tabs": "^7.7.3",
    "@react-navigation/elements": "^2.8.1",
    "@react-navigation/native": "^7.1.28",
    "apollo3-cache-persist": "^0.15.0",
    "expo": "^55.0.0",
    "expo-build-properties": "~55.0.10",
    "expo-constants": "~55.0.7",
    "expo-crypto": "~55.0.8",
    "expo-dev-client": "~55.0.10",
    "expo-device": "~55.0.9",
    "expo-font": "~55.0.4",
    "expo-glass-effect": "~55.0.7",
    "expo-haptics": "^55.0.8",
    "expo-image": "~55.0.5",
    "expo-linear-gradient": "^55.0.8",
    "expo-linking": "~55.0.7",
    "expo-router": "~55.0.3",
    "expo-secure-store": "~55.0.8",
    "expo-sharing": "~55.0.18",
    "expo-splash-screen": "~55.0.10",
    "expo-status-bar": "~55.0.4",
    "expo-symbols": "~55.0.4",
    "expo-system-ui": "~55.0.9",
    "expo-web-browser": "~55.0.9",
    "graphql": "^16.13.0",
    "newrelic-react-native-agent": "^1.7.2",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-native": "0.83.6",
    "react-native-gesture-handler": "~2.30.0",
    "react-native-google-mobile-ads": "^16.3.1",
    "react-native-mmkv": "^3.3.3",
    "react-native-nitro-modules": "^0.35.0",
    "react-native-reanimated": "4.2.1",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.23.0",
    "react-native-svg": "^15.15.3",
    "react-native-view-shot": "4.0.3",
    "react-native-web": "~0.21.0",
    "react-native-worklets": "0.7.4",
    "valtio": "^2.3.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@graphql-codegen/cli": "^6.1.2",
    "@graphql-codegen/client-preset": "^5.2.3",
    "@graphql-codegen/fragment-matcher": "^6.0.0",
    "@graphql-typed-document-node/core": "^3.2.0",
    "@parcel/watcher": "^2.5.6",
    "@testing-library/react-native": "^13.3.3",
    "@types/jest": "29.5.14",
    "@types/react": "~19.2.2",
    "eslint": "^9.0.0",
    "eslint-config-expo": "~55.0.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-no-relative-import-paths": "^1.6.1",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-native": "^5.0.0",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "globals": "^17.3.0",
    "jest": "~29.7.0",
    "jest-expo": "~55.0.9",
    "typescript": "~5.9.2",
    "typescript-eslint": "^8.56.1"
  },
  "private": true,
  "packageManager": "pnpm@10.30.3"
}
