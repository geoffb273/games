{
  "expo": {
    "name": "Game Brain",
    "slug": "game-brain",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "games-brain",
    "userInterfaceStyle": "automatic",
    "ios": {
      "icon": "./assets/icon.png",
      "bundleIdentifier": "com.gamebrain.app",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#208AEF"
        }
      ],
      "expo-secure-store",
      "expo-font"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "c5f165c1-31f4-4add-8fbd-d700f9be5db6"
      }
    }
  }
}
