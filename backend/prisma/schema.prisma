// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider     = "postgresql"
  relationMode = "prisma"
}

model User {
  id       String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  deviceId String @unique

  attempts        UserPuzzleAttempt[]
  userPuzzleHints UserPuzzleHint[]
}

model PuzzleType {
  type        String  @id @unique
  name        String
  description String?
  active      Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  puzzles Puzzle[]
}

model DailyChallenge {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  date      DateTime @unique @db.Date
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  puzzles Puzzle[]
}

model Puzzle {
  id String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid

  data      Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  dailyChallengeId String         @db.Uuid
  dailyChallenge   DailyChallenge @relation(fields: [dailyChallengeId], references: [id])
  type             String
  puzzleType       PuzzleType     @relation(fields: [type], references: [type])

  attempts        UserPuzzleAttempt[]
  userPuzzleHints UserPuzzleHint[]

  @@unique([dailyChallengeId, type])
  @@index([type])
}

model UserPuzzleAttempt {
  id String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid

  startedAt   DateTime  @default(now())
  completedAt DateTime?
  durationMs  Int?
  hintsUsed   Int       @default(0)

  userId   String @db.Uuid
  user     User   @relation(fields: [userId], references: [id])
  puzzleId String @db.Uuid
  puzzle   Puzzle @relation(fields: [puzzleId], references: [id])

  @@unique([userId, puzzleId])
  @@index([puzzleId])
}

model UserPuzzleHint {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userId   String @db.Uuid
  user     User   @relation(fields: [userId], references: [id])
  puzzleId String @db.Uuid
  puzzle   Puzzle @relation(fields: [puzzleId], references: [id])

  adRewardVerificationId String?                          @db.Uuid
  adRewardVerification   AdvertisementRewardVerification? @relation(fields: [adRewardVerificationId], references: [id])

  @@index([userId, puzzleId])
  @@index([puzzleId])
  @@index([adRewardVerificationId])
}

model AdvertisementRewardType {
  type      String   @id @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  verifications AdvertisementRewardVerification[]
}

model AdvertisementRewardVerification {
  id        String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  uniqueKey String @unique

  admobTransactionId String   @unique
  userId             String   @db.Uuid
  // Required for type PUZZLE_HINT
  puzzleId           String?  @db.Uuid
  expiresAt          DateTime

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  type                    String
  advertisementRewardType AdvertisementRewardType @relation(fields: [type], references: [type])

  userPuzzleHints UserPuzzleHint[]

  @@index([type])
  @@index([userId, type, expiresAt])
}
