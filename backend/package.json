{
  "name": "backend",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "tsc": "tsc",
    "start": "tsx src/index.ts",
    "generate:schema": "tsx src/generate-schema.ts",
    "check:schema": "tsx src/generate-schema.ts --check",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "prepare": "cd .. && node backend/node_modules/husky/bin.js"
  },
  "dependencies": {
    "@apollo/server": "^5.4.0",
    "@pothos/core": "^4.12.0",
    "@pothos/plugin-errors": "^4.9.0",
    "@pothos/plugin-relay": "^4.7.0",
    "@pothos/plugin-simple-objects": "^4.1.3",
    "@pothos/plugin-validation": "^4.2.0",
    "graphql": "^16.10.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^22.13.4",
    "eslint": "^10.0.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "husky": "^9.1.7",
    "tsx": "^4.19.3",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.56.1"
  },
  "packageManager": "pnpm@10.30.3"
}
