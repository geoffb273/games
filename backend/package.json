{
  "name": "backend",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "tsc": "tsc",
    "start": "tsx src/index.ts",
    "generate": "prisma generate",
    "generate:schema": "tsx src/generate-schema.ts",
    "check:schema": "tsx src/generate-schema.ts --check",
    "migrate:create": "prisma migrate dev --create-only",
    "migrate:deploy": "prisma migrate deploy",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "prepare": "cd .. && node backend/node_modules/husky/bin.js"
  },
  "dependencies": {
    "@apollo/server": "^5.4.0",
    "@pothos/core": "^4.12.0",
    "@pothos/plugin-errors": "^4.9.0",
    "@pothos/plugin-relay": "^4.7.0",
    "@pothos/plugin-simple-objects": "^4.1.3",
    "@pothos/plugin-validation": "^4.2.0",
    "@pothos/plugin-with-input": "^4.1.4",
    "@prisma/adapter-pg": "^7.4.2",
    "@prisma/client": "^7.4.2",
    "dotenv": "^17.3.1",
    "graphql": "^16.10.0",
    "pg": "^8.19.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^22.13.4",
    "@types/pg": "^8.16.0",
    "eslint": "^10.0.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "husky": "^9.1.7",
    "prisma": "^7.4.2",
    "tsx": "^4.19.3",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.56.1"
  },
  "packageManager": "pnpm@10.30.3"
}
